# Supabase (скопируйте из Dashboard → Settings → Database; в URI допустима только латиница).
# При необходимости добавьте в конец: ?sslmode=require
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SECRET_KEY=your-secret-key-here
# URL фронтенда (Vercel), для CORS. Локально можно не задавать.
FRONTEND_URL=https://your-app.vercel.app
